FROM php:8.2-apache`n`nRUN apt-get update && apt-get install -y git curl libpng-dev libonig-dev libxml2-dev libpq-dev zip unzip`n`nRUN docker-php-ext-install pdo_pgsql mbstring exif pcntl bcmath gd`n`nRUN a2enmod rewrite`n`nENV APACHE_DOCUMENT_ROOT /var/www/html/public`nRUN sed -ri -e \"s!/var/www/html!${APACHE_DOCUMENT_ROOT}!g\" /etc/apache2/sites-available/*.conf`nRUN sed -ri -e \"s!/var/www/!${APACHE_DOCUMENT_ROOT}!g\" /etc/apache2/apache2.conf /etc/apache2/conf-available/*.conf`n`nCOPY --from=composer:latest /usr/bin/composer /usr/bin/composer`n`nWORKDIR /var/www/html`n`nCOPY . .`n`nRUN composer install --no-interaction --optimize-autoloader --no-dev`n`nRUN chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache`n`nEXPOSE 80
